# MuseCut Backend 环境变量

# Timeline 编排 LLM
# 当前后端默认调用智谱 GLM-4-Flash；未配置 GLM_API_KEY 时会走本地默认模板降级。
LLM_PROVIDER=glm
LLM_BASE_URL=
LLM_MODEL=glm-4-flash
GLM_API_KEY=
GLM_MODEL=glm-4-flash

# ACE-Step 音乐生成 API
ACESTEP_API_URL=http://localhost:8001
# auto: ACE-Step 不可用时自动用本地合成音频降级；always: 始终使用本地合成，便于离线演示/测试。
ACESTEP_MOCK_MODE=auto

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Database
DATABASE_URL=sqlite:///./musecut.db

# Storage directories
UPLOAD_DIR=uploads
EXPORT_DIR=exports
GENERATED_DIR=generated
